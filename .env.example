# ─────────────────────────────────────────
# WAJIB DIISI
# ─────────────────────────────────────────

# Token bot dari Discord Developer Portal
DISCORD_TOKEN=token_bot_kamu_di_sini

# ID server (klik kanan server > Copy Server ID)
GUILD_ID=123456789012345678

# ─────────────────────────────────────────
# OPSIONAL — ada nilai default jika kosong
# ─────────────────────────────────────────

# Prefix perintah (default: !)
BOT_PREFIX=!

# ID channel untuk log moderasi
LOG_CHANNEL_ID=

# ID role moderator
MOD_ROLE_ID=

# Level log: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
